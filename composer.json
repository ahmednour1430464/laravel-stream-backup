{
    "name": "ahmednour1430464/laravel-stream-backup",
    "description": "Streaming database backup for Laravel: dump → compress → S3 multipart upload with constant memory use. Supports MySQL, PostgreSQL, SQLite, and custom drivers.",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "backup",
        "streaming",
        "s3",
        "digitalocean-spaces",
        "mysql",
        "postgresql",
        "sqlite",
        "pg_dump",
        "mysqldump",
        "pigz",
        "multi-driver"
    ],
    "authors": [
        {
            "name": "ahmednour",
            "email": "ahmednour1430464@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-hash": "*",
        "ext-pcntl": "*",
        "aws/aws-sdk-php": "^3.380",
        "illuminate/bus": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/console": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/queue": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.0 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Ahmednour\\StreamBackup\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ahmednour\\StreamBackup\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ahmednour\\StreamBackup\\StreamBackupServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "policy": {
            "advisories": {
                "ignore-id": [
                    "PKSA-mdq4-51ck-6kdq",
                    "PKSA-8qx3-n5y5-vvnd",
                    "PKSA-w7xr-vk7n-rstm"
                ]
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
