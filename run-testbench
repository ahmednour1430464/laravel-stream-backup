#!/usr/bin/env bash
# Launcher that sources .env into the shell environment so that
# Testbench's skeleton Laravel app can see your DB + Spaces creds.
#
# Usage:
#   ./run-testbench migrate
#   ./run-testbench backup:all
#   ./run-testbench backup:tenant 1
#   ./run-testbench backup:cleanup
#   ./run-testbench tinker

set -euo pipefail

cd "$(dirname "$0")"

if [[ ! -f .env ]]; then
  echo ".env not found in $(pwd)" >&2
  exit 1
fi

set -a
# shellcheck disable=SC1091
source ./.env
set +a

exec vendor/bin/testbench "$@"
